# ============================================================
# AIHive Command Center — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.
#
# For val.town deployment: set VALTOWN_TOKEN + VALTOWN_USERNAME
# locally, then set all other keys as val.town Environment
# Variables in your val settings dashboard.
# ============================================================

# ----------------------------------------------------------
# Val.town Deployment (local only — not stored in val.town)
# ----------------------------------------------------------
VALTOWN_TOKEN=your_val_town_api_token
VALTOWN_USERNAME=your_val_town_username

# ----------------------------------------------------------
# Ahrefs
# ----------------------------------------------------------
# Get from: ahrefs.com → Account → API
AHREFS_API_KEY=

# ----------------------------------------------------------
# Google (shared OAuth token used by GA4, GSC, YouTube)
# ----------------------------------------------------------
# Create credentials at: console.cloud.google.com
# Enable: Analytics Data API, Search Console API, YouTube Data API v3
GOOGLE_ACCESS_TOKEN=

# GA4 — find in: GA4 Admin → Property Settings → Property ID
GOOGLE_PROPERTY_ID=

# Google Search Console — verified site URL (e.g. https://example.com)
GOOGLE_SITE_URL=

# ----------------------------------------------------------
# LinkedIn
# ----------------------------------------------------------
# App at: linkedin.com/developers
# Required OAuth scopes: r_liteprofile, r_emailaddress, w_member_social
LINKEDIN_ACCESS_TOKEN=

# ----------------------------------------------------------
# Microsoft Outlook
# ----------------------------------------------------------
# App registration at: portal.azure.com → App registrations
# Required permissions: Mail.Read, Mail.Send, Calendars.Read
MICROSOFT_ACCESS_TOKEN=

# ----------------------------------------------------------
# WordPress
# ----------------------------------------------------------
# Application Passwords at: WP Admin → Users → Profile → Application Passwords
WORDPRESS_SITE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# ----------------------------------------------------------
# YouTube
# ----------------------------------------------------------
# API key at: console.cloud.google.com → APIs → YouTube Data API v3
# (Use GOOGLE_ACCESS_TOKEN above for private data / OAuth)
YOUTUBE_API_KEY=

# ----------------------------------------------------------
# Product Hunt
# ----------------------------------------------------------
# App at: producthunt.com/v2/oauth/applications
PRODUCTHUNT_API_KEY=

# ----------------------------------------------------------
# LLM Configuration
# ----------------------------------------------------------
# Provider: "anthropic" | "openai" | "custom"
LLM_PROVIDER=anthropic

# API key for the selected provider
# Anthropic: console.anthropic.com → API Keys
# OpenAI:    platform.openai.com → API Keys
LLM_API_KEY=

# Model identifier (provider-specific)
# Anthropic examples: claude-sonnet-4-6, claude-opus-4-5, claude-haiku-3-5
# OpenAI examples:    gpt-4o, gpt-4o-mini, o1-preview
LLM_MODEL=claude-sonnet-4-6

# Custom endpoint (only required when LLM_PROVIDER=custom)
# Must be an OpenAI-compatible chat/completions API
LLM_CUSTOM_BASE_URL=
